# ==============================================================
# Control Horario — Variables de entorno
# Copia este fichero como .env y ajusta los valores
# ==============================================================

# --- Base de datos ---
POSTGRES_DB=control_horario
POSTGRES_USER=horario_user
POSTGRES_PASSWORD=changeme_secret_password_here

# --- Seguridad JWT ---
# Genera una clave larga y aleatoria: openssl rand -hex 64
SECRET_KEY=cambia_esto_por_una_clave_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Usuario Admin inicial (se crea en el primer arranque) ---
ADMIN_EMAIL=admin@tuempresa.com
ADMIN_PASSWORD=Admin1234!
ADMIN_DNI=00000000A
ADMIN_NOMBRE=Administrador
ADMIN_APELLIDOS=Sistema

# --- Servidor / Red ---
# Puerto en el que escucha el contenedor de frontend
APP_PORT=80

# URL de la API tal como la ve el frontend (detrás de Nginx)
VITE_API_URL=/api

# --- Entorno ---
# production | development
ENVIRONMENT=production
